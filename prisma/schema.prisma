datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// --- Enums ---

enum WorkType {
  DEEP_WORK
  OPERATIONAL
  REACTIVE
}

enum EnergyLevel {
  FOCUSED
  STEADY
  FADING
}

enum SessionState {
  ACTIVE
  ENDED_BY_USER
  ENDED_BY_TIMEOUT
}

enum CycleState {
  RUNNING
  PAUSED
  COMPLETED
  INTERRUPTED
}

enum CycleKind {
  WORK
  SHORT_BREAK
  LONG_BREAK
}

enum SuggestionContext {
  POST_CHECK_IN
  KICKOFF
}

enum CycleEndAudioMode {
  NORMAL
  SOFT
  MUTED
}

enum CommitmentHorizon {
  ASAP
  THIS_WEEK
  WHEN_POSSIBLE
}


// --- Models ---

model Task {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(256)
  status    String    @default("active") @db.VarChar(20)
  userId    String    @map("user_id") @db.VarChar(255)
  workType           WorkType           @default(OPERATIONAL) @map("work_type")
  weight             Int                @default(2) @db.SmallInt
  importance         Int                @default(2) @db.SmallInt
  urgency            Int                @default(2) @db.SmallInt
  effortMinutes      Int?               @map("effort_minutes")
  commitmentHorizon  CommitmentHorizon  @default(WHEN_POSSIBLE) @map("commitment_horizon")
  sortOrder          Int                @default(0) @map("sort_order")
  resumeNote         String?            @map("resume_note") @db.VarChar(120)
  personaPresetId    String?            @map("persona_preset_id") @db.VarChar(32)
  createdAt DateTime  @default(now()) @map("createdAt") @db.Timestamptz
  updatedAt DateTime? @updatedAt @map("updatedAt") @db.Timestamptz

  cycles Cycle[]

  suggestedDecisions SuggestionDecision[] @relation("SuggestedTask")
  chosenDecisions    SuggestionDecision[] @relation("ChosenTask")

  @@index([status], name: "task_status_idx")
  @@index([userId], name: "task_user_id_idx")
  @@index([userId, sortOrder], name: "task_user_sort_order_idx")
  @@index([workType], name: "task_work_type_idx")
  @@map("flow_state_task")
}

model Session {
  id               Int          @id @default(autoincrement())
  userId           String       @map("user_id") @db.VarChar(255)
  state            SessionState @default(ACTIVE)
  startedAt        DateTime     @default(now()) @map("started_at") @db.Timestamptz
  endedAt          DateTime?    @map("ended_at") @db.Timestamptz
  lastActivityAt   DateTime     @default(now()) @map("last_activity_at") @db.Timestamptz
  interruptionCount Int         @default(0) @map("interruption_count")
  archivedAt       DateTime?    @map("archived_at") @db.Timestamptz
  closureLine      String?      @map("closure_line") @db.VarChar(120)

  cycles              Cycle[]
  suggestionDecisions SuggestionDecision[]

  @@index([userId], name: "session_user_id_idx")
  @@index([state], name: "session_state_idx")
  @@map("flow_state_session")
}

model Cycle {
  id                   Int        @id @default(autoincrement())
  sessionId            Int        @map("session_id")
  userId               String     @map("user_id") @db.VarChar(255)
  taskId               Int?       @map("task_id")
  kind                 CycleKind
  state                CycleState @default(RUNNING)
  configuredDurationSec Int       @map("configured_duration_sec")
  startedAt            DateTime   @default(now()) @map("started_at") @db.Timestamptz
  endedAt              DateTime?  @map("ended_at") @db.Timestamptz
  pausedAt             DateTime?  @map("paused_at") @db.Timestamptz
  remainingDurationSec Int?       @map("remaining_duration_sec")
  intention            String?    @db.VarChar(80)

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  checkIn             CheckIn?
  suggestionDecision  SuggestionDecision?

  @@index([sessionId], name: "cycle_session_id_idx")
  @@index([userId], name: "cycle_user_id_idx")
  @@index([taskId], name: "cycle_task_id_idx")
  @@map("flow_state_cycle")
}

model CheckIn {
  id          Int         @id @default(autoincrement())
  cycleId     Int         @unique @map("cycle_id")
  userId      String      @map("user_id") @db.VarChar(255)
  energy      EnergyLevel
  respondedAt DateTime    @default(now()) @map("responded_at") @db.Timestamptz

  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([userId], name: "check_in_user_id_idx")
  @@map("flow_state_check_in")
}

model SuggestionDecision {
  id              Int               @id @default(autoincrement())
  userId          String            @map("user_id") @db.VarChar(255)
  cycleId         Int?              @unique @map("cycle_id")
  sessionId       Int?              @map("session_id")
  context         SuggestionContext @default(POST_CHECK_IN)
  suggestedTaskId Int               @map("suggested_task_id")
  chosenTaskId    Int               @map("chosen_task_id")
  accepted        Boolean
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz

  cycle         Cycle?   @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  session       Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  suggestedTask Task     @relation("SuggestedTask", fields: [suggestedTaskId], references: [id], onDelete: Cascade)
  chosenTask    Task     @relation("ChosenTask", fields: [chosenTaskId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], name: "suggestion_decision_user_created_idx")
  @@index([sessionId, createdAt], name: "suggestion_decision_session_created_idx")
  @@map("flow_state_suggestion_decision")
}
model UserPreference {
  userId              String             @id @map("user_id") @db.VarChar(255)
  cycleEndAudioMode   CycleEndAudioMode  @default(NORMAL) @map("cycle_end_audio_mode")
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  @@map("flow_state_user_preference")
}

