{
	"mcpServers": {
		"context7": {
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp@latest"],
			"disabled": false,
			"autoApprove": ["resolve-library-id", "query-docs"]
		},
		"vercel": {
			"url": "https://mcp.vercel.com",
			"autoApprove": [
				"list_deployments",
				"get_deployment_build_logs",
				"get_deployment",
				"get_runtime_logs"
			],
			"disabledTools": [
				"deploy_to_vercel",
				"get_runtime_logs",
				"add_toolbar_reaction",
				"edit_toolbar_message",
				"reply_to_toolbar_thread",
				"change_toolbar_thread_resolve_status",
				"get_toolbar_thread",
				"list_toolbar_threads",
				"check_domain_availability_and_price",
				"list_teams"
			]
		},
		"exa": {
			"url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
			"autoApprove": [
				"web_search_exa",
				"web_fetch_exa",
				"web_search_advanced_exa"
			]
		},
		"linear-flowstate": {
			"url": "https://mcp.linear.app/mcp",
			"autoApprove": [
				"list_issue_labels",
				"list_issue_statuses",
				"save_project",
				"create_issue_label",
				"save_issue",
				"list_issues",
				"get_issue",
				"search_documentation",
				"save_milestone",
				"save_document",
				"list_cycles",
				"save_comment",
				"list_teams",
				"list_projects"
			]
		}
	},
	"powers": {
		"mcpServers": {
			"power-context7-context7": {
				"url": "https://mcp.context7.com/mcp"
			},
			"power-snyk-secure-at-inception-Snyk": {
				"command": "npx",
				"args": ["-y", "snyk@latest", "mcp", "-t", "stdio"]
			},
			"power-neon-Neon": {
				"url": "https://mcp.neon.tech/mcp",
				"disabled": false,
				"disabledTools": ["compare_database_schema"]
			}
		}
