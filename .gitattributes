# Match .editorconfig: end_of_line = lf
* text=auto eol=lf

# Definite binaries — never normalize line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp3 binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.wasm binary
